# MongoDB connection string.
# Local MongoDB:        mongodb://localhost:27017/waypoint
# MongoDB Atlas (free):  mongodb+srv://<username>:<password>@<cluster-url>/waypoint?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/waypoint

# Port the API server listens on
PORT=5000

# URL of the deployed/local frontend, used for CORS.
# Use * during local development if you like, but set a real origin in production.
CLIENT_ORIGIN=http://localhost:3000
